<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
    <metadata>
        <id>Soenneker.SimpleIcons.Icons</id>
        <version>$version$</version>
        <authors>Jake Soenneker</authors>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <license type="expression">MIT</license>
        <projectUrl>https://github.com/soenneker/soenneker.simpleicons.icons</projectUrl>
        <repository type="git" url="https://github.com/soenneker/soenneker.simpleicons.icons" branch="main" commit="$repositoryCommit$" />
        <description>All of the Simple Icon svgs, updated daily</description>
        <tags>simpleicons icons simple icon simpleicon data csharp dotnet c# .net</tags>
        <readme>README.md</readme>
        <icon>icon.png</icon>
        <dependencies>
            <group targetFramework="$targetFramework$" />
        </dependencies>
        <contentFiles>
            <files include="any/any/Resources/SimpleIcons/**" buildAction="None" copyToOutput="true" />
        </contentFiles>
    </metadata>
    <files>
        <file src="bin\$configuration$\$targetFramework$\$assemblyName$.dll" target="lib\$targetFramework$" />
        <file src="bin\$configuration$\$targetFramework$\$assemblyName$.xml" target="lib\$targetFramework$" />
        <file src="Resources\**\*.*" target="contentFiles\any\any\Resources\SimpleIcons" />
        <file src="..\..\README.md" target="README.md" />
        <file src="..\..\LICENSE" target="LICENSE" />
        <file src="..\..\icon.png" target="icon.png" />
    </files>
</package>
